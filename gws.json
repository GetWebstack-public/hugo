{
  "name": "hugo",
  "version": "1.0.0",
  "registry": {
    "mode": "local"
  },
  "services": [
    {
      "name": "hugo",
      "path": ".",
      "port": 1313,
      "hosts": ["hugo.hugo.local.getwebstack.dev"],
      "dockerfile": ".gws/services/hugo/Dockerfile",
      "manifests": ".gws/services/hugo/k8s",
      "fileSync": true,
      "fileSyncIgnore": [
        "/.git",
        "/.idea",
        "/.vscode",
        "/.DS_Store",
        "public/",
        "resources/",
        "node_modules/",
        ".hugo_build.lock"
      ]
    }
  ],
  "provision": {
    "environments": {
      "dev": {
        "type": "k3d",
        "default": true
      }
    }
  }
}
